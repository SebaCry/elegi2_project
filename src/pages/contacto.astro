---
import Layout from "../layouts/Layout.astro";
import ContactoForm from "../components/Contacto.astro";
---

<Layout
  title="Contáctanos — ELEGI2"
  description="Agenda una llamada con uno de los pastores. 20 minutos. Sin agenda escondida."
>
  <section
    class="relative min-h-[55vh] flex items-end overflow-hidden bg-ink pt-32 pb-16 md:pt-40 md:pb-24"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-20 right-[-6vw] select-none"
    >
      <span
        class="font-display text-cream/[0.05] leading-none block"
        style="font-size: clamp(18rem, 40vw, 48rem); letter-spacing: -0.06em;"
      >
        HOLA
      </span>
    </div>

    <div class="relative z-10 max-w-[1600px] mx-auto px-6 md:px-10 w-full">
      <p class="eyebrow mb-8 animate-fade-in-up animate-duration-1000">
        Contáctanos
      </p>
      <h1
        class="font-display uppercase text-bone leading-[0.88] animate-reveal-mask max-w-5xl"
        style="font-size: clamp(2.75rem, 9vw, 8rem); letter-spacing: -0.05em;"
      >
        Una llamada.
        <br />
        <span class="text-cream">Una oración.</span>
      </h1>
      <p
        class="mt-10 max-w-2xl font-serif italic text-2xl md:text-3xl text-bone leading-relaxed animate-fade-in-up animate-delay-500 animate-duration-1000"
      >
        Déjanos tus datos y uno de nosotros te escribe para coordinar.
      </p>
    </div>
  </section>

  <ContactoForm />
</Layout>
