---
const featured = {
  cat: "Reflexión",
  date: "01 May 2026",
  read: "8 min de lectura",
  author: "María González",
  title: "Cuando Dios responde con un “todavía no”",
  excerpt:
    "Hay oraciones que no se contestan con sí. Tampoco con no. Y aprender a vivir en ese “todavía no” es, tal vez, la lección más difícil de la fe.",
};

const articulos = [
  {
    n: "01",
    cat: "Devocional",
    date: "28 Abr",
    read: "5 min",
    author: "Juan Pérez",
    title: "Lo que aprendí orando por mi enemigo",
  },
  {
    n: "02",
    cat: "Práctica",
    date: "24 Abr",
    read: "4 min",
    author: "Camilo Ríos",
    title: "5 versículos que cambiaron mi forma de empezar el día",
  },
  {
    n: "03",
    cat: "Reflexión",
    date: "20 Abr",
    read: "7 min",
    author: "María González",
    title: "Cómo leer la Biblia cuando nada tiene sentido",
  },
  {
    n: "04",
    cat: "Testimonio",
    date: "15 Abr",
    read: "6 min",
    author: "Juan Pérez",
    title: "El silencio de Dios no es ausencia",
  },
  {
    n: "05",
    cat: "Cultura",
    date: "10 Abr",
    read: "9 min",
    author: "Camilo Ríos",
    title: "Vivir el evangelio en redes sociales sin perder el alma",
  },
];

const tags = ["Todos", "Reflexión", "Devocional", "Testimonio", "Práctica", "Cultura"];
---

<section
  id="blog"
  class="relative bg-ink-soft border-t border-ink-line py-28 md:py-40 overflow-hidden"
>
  <div class="max-w-[1600px] mx-auto px-6 md:px-10">
    <!-- Header -->
    <div class="grid grid-cols-12 gap-6 items-end mb-20">
      <div class="col-span-12 md:col-span-7 reveal">
        <p class="eyebrow mb-8">Capítulo 04 — Blog</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          Palabras
          <br />
          <span class="text-cream">que se quedan.</span>
        </h2>
      </div>
      <div class="col-span-12 md:col-span-4 md:col-start-9 reveal delay-2">
        <p class="font-serif italic text-bone text-lg leading-relaxed">
          Reflexiones, devocionales y conversaciones — escritas a tres manos,
          publicadas cada semana sin filtro corporativo.
        </p>
      </div>
    </div>

    <!-- Artículo destacado tipo portada de revista -->
    <article class="reveal mb-24 group cursor-pointer">
      <div
        class="grid grid-cols-12 gap-6 md:gap-12 border-y border-ink-line py-12 md:py-16 hover:bg-ink/40 transition-colors duration-700"
      >
        <!-- Lado izquierdo: número + meta + ★ -->
        <div class="col-span-12 md:col-span-2 flex md:flex-col justify-between md:justify-start md:gap-10">
          <span
            class="font-display text-cream leading-none"
            style="font-size: clamp(4rem, 8vw, 7rem); letter-spacing: -0.05em;"
          >★</span>
          <div class="md:mt-auto space-y-3">
            <p class="text-[12px] tracking-[0.32em] uppercase text-cream-deep">
              {featured.cat}
            </p>
            <p class="text-[12px] tracking-[0.28em] uppercase text-bone-muted">
              {featured.date}
            </p>
          </div>
        </div>

        <!-- Centro: título + excerpt -->
        <div class="col-span-12 md:col-span-8">
          <h3
            class="font-serif italic text-bone leading-[1.02] group-hover:text-cream transition-colors duration-700"
            style="font-size: clamp(2.25rem, 5vw, 4.5rem);"
          >
            {featured.title}
          </h3>
          <p class="mt-8 text-bone text-lg md:text-xl leading-relaxed max-w-2xl">
            {featured.excerpt}
          </p>
          <p class="mt-8 text-[13px] tracking-[0.28em] uppercase text-bone-muted">
            Por {featured.author} · {featured.read}
          </p>
        </div>

        <!-- Derecha: flecha -->
        <div class="col-span-12 md:col-span-2 flex md:justify-end items-end">
          <span
            class="font-display text-cream text-7xl md:text-8xl leading-none group-hover:translate-x-2 transition-transform duration-500"
          >→</span>
        </div>
      </div>
    </article>

    <!-- Filtros / tags -->
    <div class="reveal flex flex-wrap items-center gap-2 mb-12">
      {
        tags.map((t, i) => (
          <button
            class:list={[
              "text-[13px] tracking-[0.28em] uppercase px-4 py-2.5 border transition-all duration-500",
              i === 0
                ? "bg-cream text-ink border-cream"
                : "border-ink-line text-bone-muted hover:border-cream hover:text-cream",
            ]}
          >
            {t}
          </button>
        ))
      }
    </div>

    <!-- Listado tabla-de-contenido -->
    <ul class="border-t border-ink-line">
      {
        articulos.map((a, i) => (
          <li class:list={["reveal", `delay-${(i % 3) + 1}`]}>
            <a
              href="#"
              class="grid grid-cols-12 gap-4 md:gap-8 items-baseline border-b border-ink-line py-8 md:py-10 group hover:bg-ink/40 transition-colors duration-700"
            >
              <span class="col-span-2 md:col-span-1 font-display text-cream-deep text-2xl md:text-3xl leading-none">
                {a.n}
              </span>
              <span class="col-span-10 md:col-span-2 text-[12px] tracking-[0.32em] uppercase text-cream-deep">
                {a.cat}
              </span>
              <h3 class="col-span-12 md:col-span-6 font-serif italic text-bone text-2xl md:text-[28px] leading-[1.15] group-hover:text-cream transition-colors duration-500">
                {a.title}
              </h3>
              <span class="col-span-6 md:col-span-2 text-xs tracking-[0.22em] uppercase text-bone-muted">
                {a.author} · {a.read}
              </span>
              <span class="col-span-6 md:col-span-1 flex justify-end font-display text-cream text-3xl group-hover:translate-x-1 transition-transform">
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Newsletter inline -->
    <div
      class="reveal mt-24 border border-ink-line bg-ink/40 p-10 md:p-16 grid grid-cols-12 gap-6 items-end"
    >
      <div class="col-span-12 md:col-span-7">
        <p class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-6">
          Carta semanal
        </p>
        <h3
          class="font-display uppercase text-bone leading-[0.92]"
          style="font-size: clamp(1.75rem, 4vw, 3.25rem); letter-spacing: -0.04em;"
        >
          Una palabra cada lunes,
          <br />
          <span class="text-cream">directo a tu correo.</span>
        </h3>
        <p class="mt-5 font-serif italic text-bone text-lg max-w-md">
          Sin spam, sin venta, sin fórmulas. Solo lo que estamos aprendiendo esa semana.
        </p>
      </div>
      <form
        class="col-span-12 md:col-span-5 flex flex-col sm:flex-row gap-3"
        onsubmit="event.preventDefault(); this.querySelector('button').textContent='Suscrito ✦'; this.reset();"
      >
        <input
          type="email"
          required
          placeholder="tu@correo.com"
          class="field flex-1"
        />
        <button type="submit" class="btn-elegi shrink-0 justify-center">
          Suscribirme
        </button>
      </form>
    </div>
  </div>
</section>
