---
const links = [
  { href: "#nosotros", label: "Nosotros" },
  { href: "#proposito", label: "Propósito" },
  { href: "#recursos", label: "Recursos" },
  { href: "#blog", label: "Blog" },
  { href: "#eventos", label: "Eventos" },
  { href: "#oracion", label: "Oración" },
  { href: "#contacto", label: "Contacto" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 px-6 md:px-10 py-5 backdrop-blur-md bg-ink/70 border-b border-ink-line/60"
>
  <div class="flex items-center justify-between gap-8 max-w-[1600px] mx-auto">
    <a href="#inicio" class="flex items-center gap-3 group">
      <span
        class="font-display text-cream text-xl tracking-[-0.04em] leading-none group-hover:text-bone transition-colors"
      >
        ELEGI<span class="text-bone">2</span>
      </span>
      <span class="hidden md:inline-block w-px h-4 bg-ink-line"></span>
      <span class="hidden md:inline-block text-[12px] tracking-[0.32em] uppercase text-bone-muted">
        3 voces · 1 propósito
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-[13px] tracking-[0.28em] uppercase text-bone-muted hover:text-cream transition-colors duration-500"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <a
      href="#contacto"
      class="hidden md:inline-flex items-center gap-2 text-[13px] tracking-[0.28em] uppercase text-cream border-b border-cream/40 pb-1 hover:border-cream transition-colors"
    >
      Orar contigo
      <span aria-hidden="true">→</span>
    </a>

    <button
      id="menu-toggle"
      class="md:hidden text-cream text-[13px] tracking-[0.28em] uppercase"
      aria-label="Abrir menú"
    >
      Menú
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden pt-6 pb-2 flex-col gap-5 border-t border-ink-line mt-5"
  >
    {
      links.map((l) => (
        <a
          href={l.href}
          class="block text-[14px] tracking-[0.22em] uppercase text-bone hover:text-cream"
        >
          {l.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });
  // Close on link click
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    })
  );
</script>
