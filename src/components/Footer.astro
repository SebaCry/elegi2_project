---
const verses = [
  "“No me elegisteis vosotros a mí, sino que yo os elegí a vosotros.” — Juan 15:16",
  "“Antes que te formase en el vientre te conocí.” — Jeremías 1:5",
  "“Vosotros sois linaje escogido, real sacerdocio.” — 1 Pedro 2:9",
];
---

<footer
  id="footer"
  class="relative z-10 border-t border-ink-line bg-ink-soft text-bone-muted"
>
  <!-- Marquee versículo -->
  <div class="overflow-hidden border-b border-ink-line py-6">
    <div class="flex gap-16 whitespace-nowrap animate-marquee will-change-transform">
      {
        [...verses, ...verses, ...verses].map((v) => (
          <span class="font-serif italic text-cream/80 text-2xl md:text-3xl shrink-0">
            {v}
            <span class="mx-12 text-cream/30">✦</span>
          </span>
        ))
      }
    </div>
  </div>

  <div
    class="max-w-[1600px] mx-auto px-6 md:px-10 py-16 grid grid-cols-1 md:grid-cols-12 gap-10"
  >
    <div class="md:col-span-5">
      <span class="font-display text-cream text-4xl tracking-[-0.04em] leading-none">
        ELEGI<span class="text-bone">2</span>
      </span>
      <p class="mt-6 max-w-md font-serif text-bone text-xl leading-relaxed italic">
        Porque no lo elegimos nosotros a Él, sino que Él nos eligió primero.
      </p>
      <p class="mt-6 text-xs tracking-[0.28em] uppercase">
        <span data-today>Hoy</span>
      </p>
    </div>

    <div class="md:col-span-3">
      <h4 class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-5">
        Navega
      </h4>
      <ul class="space-y-3 text-sm">
        <li><a href="#nosotros" class="hover:text-cream transition-colors">Quiénes somos</a></li>
        <li><a href="#proposito" class="hover:text-cream transition-colors">Propósito</a></li>
        <li><a href="#recursos" class="hover:text-cream transition-colors">Recursos</a></li>
        <li><a href="#blog" class="hover:text-cream transition-colors">Blog</a></li>
        <li><a href="#eventos" class="hover:text-cream transition-colors">Eventos</a></li>
        <li><a href="#oracion" class="hover:text-cream transition-colors">Pedidos de oración</a></li>
        <li><a href="#contacto" class="hover:text-cream transition-colors">Orar contigo</a></li>
      </ul>
    </div>

    <div class="md:col-span-4">
      <h4 class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-5">
        Síguenos
      </h4>
      <ul class="space-y-3 text-sm">
        <li>
          <a href="#" class="flex items-center justify-between border-b border-ink-line pb-3 group">
            <span>Instagram</span>
            <span class="text-cream/60 group-hover:text-cream transition-colors">@elegi2</span>
          </a>
        </li>
        <li>
          <a href="#" class="flex items-center justify-between border-b border-ink-line pb-3 group">
            <span>TikTok</span>
            <span class="text-cream/60 group-hover:text-cream transition-colors">@elegi2</span>
          </a>
        </li>
        <li>
          <a href="#" class="flex items-center justify-between border-b border-ink-line pb-3 group">
            <span>YouTube</span>
            <span class="text-cream/60 group-hover:text-cream transition-colors">/elegi2</span>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div
    class="border-t border-ink-line py-6 px-6 md:px-10 flex flex-col md:flex-row items-center justify-between gap-3 text-[12px] tracking-[0.28em] uppercase"
  >
    <span>© {new Date().getFullYear()} Elegi2 · Colombia</span>
    <span class="text-cream-deep">Fe · Vida · Esperanza</span>
  </div>
</footer>
