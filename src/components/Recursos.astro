---
const featured = {
  date: "Domingo · 03 May",
  title: "“Quédate, aún hay propósito en lo que parece terminado”",
  text: "El Señor no termina lo que comienza a la mitad. Si hoy te sientes en pausa, recuerda — Lázaro también lo estuvo.",
  ref: "Juan 11 · Devocional del día",
};

const recursos = [
  {
    type: "Devocional",
    date: "02 May",
    title: "Cuando todo parece silencio, Él habla",
    duration: "5 min de lectura",
  },
  {
    type: "Podcast",
    date: "29 Abr",
    title: "Ep. 12 — Vida nueva no significa vida fácil",
    duration: "32 min de escucha",
  },
  {
    type: "Plan de lectura",
    date: "Disponible",
    title: "30 días en los Salmos",
    duration: "Plan de un mes",
  },
  {
    type: "Devocional",
    date: "28 Abr",
    title: "El milagro empieza cuando tú dejas de cargarlo todo",
    duration: "4 min de lectura",
  },
  {
    type: "Video",
    date: "25 Abr",
    title: "Lo que aprendí en mi peor año",
    duration: "12 min",
  },
  {
    type: "Plan de lectura",
    date: "Disponible",
    title: "Conociendo a Jesús en 7 días",
    duration: "Plan de una semana",
  },
];

const categorias = ["Todos", "Devocionales", "Podcast", "Video", "Planes"];
---

<section
  id="recursos"
  class="relative bg-ink-soft border-t border-ink-line py-28 md:py-40"
>
  <div class="max-w-[1600px] mx-auto px-6 md:px-10">
    <!-- Header -->
    <div class="grid grid-cols-12 gap-6 items-end mb-20">
      <div class="col-span-12 md:col-span-8 reveal">
        <p class="eyebrow mb-8">Capítulo 03 — Recursos</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          Tu palabra
          <br />
          <span class="text-cream">para hoy.</span>
        </h2>
      </div>
      <div class="col-span-12 md:col-span-3 md:col-start-10 reveal delay-2">
        <p class="font-serif italic text-bone text-lg leading-relaxed">
          Devocionales, podcast, planes de lectura — todo gratis, todo pensado para
          encontrarte donde estés hoy.
        </p>
      </div>
    </div>

    <!-- Featured: Tu palabra para hoy -->
    <article class="reveal mb-20 group cursor-pointer">
      <div
        class="grid grid-cols-12 gap-6 md:gap-12 items-stretch border-t border-b border-ink-line py-12 md:py-16 hover:bg-ink/40 transition-colors duration-700"
      >
        <div class="col-span-12 md:col-span-3 flex md:flex-col justify-between md:justify-start gap-4">
          <span class="text-[13px] tracking-[0.32em] uppercase text-cream-deep">
            ★ Hoy en Elegi2
          </span>
          <span class="text-xs tracking-[0.28em] uppercase text-bone-muted" data-today>
            {featured.date}
          </span>
        </div>
        <div class="col-span-12 md:col-span-7">
          <h3
            class="font-serif text-bone leading-[1.05] italic"
            style="font-size: clamp(2rem, 4.5vw, 4rem);"
          >
            {featured.title}
          </h3>
          <p class="mt-6 text-bone text-lg leading-relaxed max-w-2xl">
            {featured.text}
          </p>
          <p class="mt-6 text-[13px] tracking-[0.28em] uppercase text-cream">
            {featured.ref}
          </p>
        </div>
        <div class="col-span-12 md:col-span-2 flex md:justify-end items-end">
          <span
            class="font-display text-cream text-7xl md:text-8xl leading-none group-hover:translate-x-2 transition-transform duration-500"
          >
            →
          </span>
        </div>
      </div>
    </article>

    <!-- Filtros -->
    <div class="reveal flex flex-wrap items-center gap-2 mb-12">
      {
        categorias.map((c, i) => (
          <button
            class:list={[
              "text-[13px] tracking-[0.28em] uppercase px-4 py-2.5 border transition-all duration-500",
              i === 0
                ? "bg-cream text-ink border-cream"
                : "border-ink-line text-bone-muted hover:border-cream hover:text-cream",
            ]}
          >
            {c}
          </button>
        ))
      }
    </div>

    <!-- Grid de recursos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-ink-line border border-ink-line">
      {
        recursos.map((r) => (
          <article class="bg-ink-soft p-8 md:p-10 group hover:bg-ink transition-all duration-700 cursor-pointer flex flex-col justify-between min-h-[260px]">
            <div class="flex items-center justify-between mb-8">
              <span class="text-[12px] tracking-[0.32em] uppercase text-cream-deep">
                {r.type}
              </span>
              <span class="text-[12px] tracking-[0.28em] uppercase text-bone-muted">
                {r.date}
              </span>
            </div>
            <h3 class="font-serif text-bone text-2xl md:text-[26px] leading-tight italic mb-6 group-hover:text-cream transition-colors duration-500">
              {r.title}
            </h3>
            <div class="flex items-center justify-between">
              <span class="text-[12px] tracking-[0.28em] uppercase text-bone-muted">
                {r.duration}
              </span>
              <span class="text-cream font-display text-3xl leading-none translate-x-0 group-hover:translate-x-1 transition-transform">
                →
              </span>
            </div>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-16 text-center">
      <a href="#" class="btn-ghost">
        Ver todos los recursos
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
