---
type Recurso = {
  type: string;
  date: string;
  title: string;
  instagramUrl: string | null;
};

// Convierte una URL pública de Instagram en su versión /embed.
// Devuelve null si la URL es nula, vacía o no tiene formato válido,
// así el caller puede decidir qué renderizar en su lugar.
function toInstagramEmbed(url: string | null | undefined): string | null {
  if (!url) return null;
  const trimmed = url.trim();
  if (!trimmed) return null;

  const instagramPost = /^https?:\/\/(www\.)?instagram\.com\/(p|reel|tv)\/[\w-]+\/?/i;
  if (!instagramPost.test(trimmed)) return null;

  return `${trimmed.replace(/\/+$/, "")}/embed`;
}

const recursos: Recurso[] = [
  {
    type: "Podcast",
    date: "Disponible",
    title: "Ep. 12 — Vida nueva no significa vida fácil",
    instagramUrl: "https://www.instagram.com/reel/DYZah1Th4rj/",
  },
  {
    type: "Plan de lectura",
    date: "Disponible",
    title: "30 días en los Salmos",
    instagramUrl: "https://www.instagram.com/reel/DYW7JaqR1QT/",
  },
  {
    type: "Devocional",
    date: "Disponible",
    title: "Cuando todo parece silencio, Él habla",
    instagramUrl: "https://www.instagram.com/reel/DYE72iwRBtD/",
  },
];

const categorias = ["Todos"];
---

<section
  id="recursos"
  class="relative bg-ink-soft border-t border-ink-line py-16 md:py-20"
>
  <div class="max-w-[1600px] mx-auto px-6 md:px-10">
    <!-- Header -->
    <div class="grid grid-cols-12 gap-6 items-end mb-20">
      <div class="col-span-12 md:col-span-8 reveal">
        <p class="eyebrow mb-8">Recursos</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          Tu palabra
          <br />
          <span class="text-cream">para hoy.</span>
        </h2>
      </div>
      <div class="col-span-12 md:col-span-3 md:col-start-10 reveal delay-2">
        <p class="font-serif italic text-bone text-xl leading-relaxed">
          Devocionales, podcast, planes de lectura — todo gratis, todo pensado para
          encontrarte donde estés hoy.
        </p>
      </div>
    </div>

    <!-- Featured: Tu palabra para hoy -->

    <!-- Filtros -->
    <div class="reveal flex flex-wrap items-center gap-2 mb-12">
      {
        categorias.map((c, i) => (
          <button
            class:list={[
              "text-[13px] tracking-[0.28em] uppercase px-4 py-2.5 border transition-all videoClip-500",
              i === 0
                ? "bg-cream text-ink border-cream"
                : "border-ink-line text-bone-muted hover:border-cream hover:text-cream",
            ]}
          >
            {c}
          </button>
        ))
      }
    </div>

    <!-- Grid de recursos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-ink-line border border-ink-line">
      {
        recursos.map((r) => {
          const embedUrl = toInstagramEmbed(r.instagramUrl);
          return (
            <article class="bg-ink-soft group hover:bg-ink transition-all duration-700 cursor-pointer flex flex-col justify-between min-h-[260px] overflow-hidden">
              {embedUrl ? (
                <div class="bg-ink overflow-hidden">
                  <iframe
                    src={embedUrl}
                    width="100%"
                    height="640"
                    frameborder="0"
                    scrolling="no"
                    loading="lazy"
                    title={r.title}
                    class="block w-full -mt-[55px] -mb-[60px]"
                  />
                </div>
              ) : null}
              <div class="p-8 md:p-10 flex flex-col justify-between flex-1">
                <div class="flex items-center justify-between mb-8">
                  <span class="text-[12px] tracking-[0.32em] uppercase text-cream-deep">
                    {r.type}
                  </span>
                  <span class="text-[12px] tracking-[0.28em] uppercase text-bone-muted">
                    {r.date}
                  </span>
                </div>
                <h3 class="font-serif text-bone text-2xl md:text-[26px] leading-tight italic mb-6 group-hover:text-cream transition-colors duration-500">
                  {r.title}
                </h3>
                {r.instagramUrl ? (
                  <a
                    href={r.instagramUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-between hover:text-cream transition-colors"
                  >
                    <span class="text-[12px] tracking-[0.28em] uppercase text-bone-muted group-hover:text-cream transition-colors">
                      Ver en Instagram
                    </span>
                    <span class="text-cream font-display text-3xl leading-none translate-x-0 group-hover:translate-x-1 transition-transform">
                      →
                    </span>
                  </a>
                ) : (
                  <div class="flex items-center justify-between">
                    <span class="text-[12px] tracking-[0.28em] uppercase text-bone-muted">
                      Próximamente
                    </span>
                  </div>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
