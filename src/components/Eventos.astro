---
// Próximo gran evento — fechas relativas a "hoy"
const next = {
  title: "Encuentro Elegi2",
  city: "Bogotá · Movistar Arena",
  modo: "Presencial",
  dia: "17",
  mes: "Mayo",
  hora: "6:00 pm — 10:00 pm",
  speakers: "Juan · María · Camilo + invitados",
  capacidad: "12.000 personas",
  precio: "Entrada libre · cupos limitados",
};

const eventos = [
  {
    dia: "10",
    mes: "May",
    weekday: "Sábado",
    hora: "8:00 pm",
    title: "Noche de oración por Colombia",
    place: "Online · YouTube Live",
    modo: "Online",
    cupos: "Sin límite",
  },
  {
    dia: "14",
    mes: "May",
    weekday: "Miércoles",
    hora: "7:00 pm",
    title: "Live Q&A — Las preguntas que no te atreves a hacer",
    place: "Instagram · @elegi2",
    modo: "Online",
    cupos: "Sin límite",
  },
  {
    dia: "24",
    mes: "May",
    weekday: "Sábado",
    hora: "5:00 pm",
    title: "Conferencia Fe + Vida",
    place: "Medellín · Plaza Mayor",
    modo: "Presencial",
    cupos: "Quedan 320",
  },
  {
    dia: "07",
    mes: "Jun",
    weekday: "Sáb — Lun",
    hora: "Fin de semana",
    title: "Retiro de jóvenes — Eje Cafetero",
    place: "Salento · Quindío",
    modo: "Presencial",
    cupos: "Quedan 18",
  },
];
---

<section
  id="eventos"
  class="relative bg-ink border-t border-ink-line py-28 md:py-40 overflow-hidden"
>
  <!-- texto outline gigante de fondo -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-10 -left-20 select-none"
  >
    <span
      class="font-display text-cream/[0.05] leading-none block"
      style="font-size: clamp(20rem, 50vw, 55rem); letter-spacing: -0.06em;"
    >
      EN VIVO
    </span>
  </div>

  <div class="relative max-w-[1600px] mx-auto px-6 md:px-10">
    <!-- Header -->
    <div class="grid grid-cols-12 gap-6 items-end mb-20">
      <div class="col-span-12 md:col-span-7 reveal">
        <p class="eyebrow mb-8">Capítulo 05 — Eventos</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          Nos vemos
          <br />
          <span class="text-cream">en persona.</span>
        </h2>
      </div>
      <div class="col-span-12 md:col-span-4 md:col-start-9 reveal delay-2">
        <p class="font-serif italic text-bone text-lg leading-relaxed">
          Encuentros presenciales, lives, retiros y noches de oración. La
          comunidad sucede cuando dejamos de ser pantalla y nos volvemos rostro.
        </p>
      </div>
    </div>

    <!-- Próximo evento — gigante, calendario brutal -->
    <article class="reveal mb-24">
      <div class="border border-ink-line bg-ink-soft grid grid-cols-12 gap-0">
        <!-- Bloque fecha mega -->
        <div
          class="col-span-12 md:col-span-4 lg:col-span-3 bg-cream text-ink p-8 md:p-10 flex flex-col justify-between min-h-[260px] relative overflow-hidden"
        >
          <span class="text-[12px] tracking-[0.32em] uppercase">
            ★ Próximo encuentro
          </span>
          <div>
            <span
              class="font-display block leading-[0.78]"
              style="font-size: clamp(7rem, 14vw, 14rem); letter-spacing: -0.06em;"
            >
              {next.dia}
            </span>
            <span class="font-display uppercase text-3xl md:text-4xl tracking-tight leading-none mt-1 block">
              {next.mes}
            </span>
          </div>
          <span class="text-[12px] tracking-[0.32em] uppercase font-medium">
            {next.hora}
          </span>
        </div>

        <!-- Detalles -->
        <div class="col-span-12 md:col-span-8 lg:col-span-9 p-8 md:p-12 flex flex-col justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-3 mb-6">
              <span class="text-[12px] tracking-[0.32em] uppercase text-ink bg-cream px-3 py-1.5">
                {next.modo}
              </span>
              <span class="text-[12px] tracking-[0.32em] uppercase text-cream-deep">
                {next.city}
              </span>
            </div>
            <h3
              class="font-display uppercase text-bone leading-[0.92]"
              style="font-size: clamp(2.25rem, 5.5vw, 5rem); letter-spacing: -0.04em;"
            >
              {next.title}
            </h3>
            <p class="mt-6 font-serif italic text-bone text-lg md:text-xl max-w-2xl leading-relaxed">
              Una noche de adoración, palabra y testimonios. Si pudieras llevar a
              alguien, ¿a quién llevarías? — esa persona también está invitada.
            </p>
          </div>

          <div
            class="mt-10 grid grid-cols-2 md:grid-cols-3 gap-y-6 gap-x-8 border-t border-ink-line pt-8"
          >
            <div>
              <p class="text-[12px] tracking-[0.32em] uppercase text-cream-deep mb-2">
                Voces en el escenario
              </p>
              <p class="text-bone text-sm">{next.speakers}</p>
            </div>
            <div>
              <p class="text-[12px] tracking-[0.32em] uppercase text-cream-deep mb-2">
                Capacidad
              </p>
              <p class="text-bone text-sm">{next.capacidad}</p>
            </div>
            <div>
              <p class="text-[12px] tracking-[0.32em] uppercase text-cream-deep mb-2">
                Entrada
              </p>
              <p class="text-bone text-sm">{next.precio}</p>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a href="#" class="btn-elegi">
              Reservar mi cupo
              <span aria-hidden="true">→</span>
            </a>
            <a href="#" class="btn-ghost">Compartir</a>
          </div>
        </div>
      </div>
    </article>

    <!-- Próximos eventos — listado calendario -->
    <p class="reveal text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-8">
      Próximos encuentros
    </p>

    <ul class="border-t border-ink-line">
      {
        eventos.map((e, i) => (
          <li class:list={["reveal", `delay-${(i % 3) + 1}`]}>
            <a
              href="#"
              class="grid grid-cols-12 gap-4 md:gap-8 items-center border-b border-ink-line py-8 md:py-10 group hover:bg-ink-soft/60 transition-colors duration-700"
            >
              <!-- Fecha -->
              <div class="col-span-3 md:col-span-2 lg:col-span-1 flex items-baseline gap-2">
                <span
                  class="font-display text-cream leading-none"
                  style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em;"
                >
                  {e.dia}
                </span>
                <span class="font-display uppercase text-cream-deep text-base md:text-xl tracking-tight">
                  {e.mes}
                </span>
              </div>

              <span class="hidden lg:block col-span-1 text-[12px] tracking-[0.32em] uppercase text-bone-muted">
                {e.weekday}
              </span>

              <span class="col-span-9 md:col-span-2 lg:col-span-1 text-[12px] tracking-[0.32em] uppercase text-bone-muted">
                {e.hora}
              </span>

              <h3 class="col-span-12 md:col-span-5 lg:col-span-5 font-serif italic text-bone text-xl md:text-2xl leading-snug group-hover:text-cream transition-colors duration-500">
                {e.title}
              </h3>

              <span class="col-span-7 md:col-span-2 text-xs text-bone-muted">
                {e.place}
              </span>

              <span
                class:list={[
                  "col-span-3 md:col-span-1 text-[12px] tracking-[0.32em] uppercase px-2 py-1 text-center border",
                  e.modo === "Presencial"
                    ? "border-cream text-cream"
                    : "border-ink-line text-bone-muted",
                ]}
              >
                {e.modo}
              </span>

              <span class="col-span-2 md:col-span-1 text-[12px] tracking-[0.28em] uppercase text-bone-muted text-right">
                {e.cupos}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="reveal mt-16 flex flex-wrap items-center justify-between gap-6">
      <p class="font-serif italic text-bone-muted text-base max-w-md">
        “Donde están dos o tres reunidos en mi nombre, allí estoy yo en medio de
        ellos.” — Mateo 18:20
      </p>
      <a href="#" class="btn-ghost">
        Ver agenda completa
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
