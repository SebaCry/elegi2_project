---
const horarios = [
  { dia: "Lun — Vie", hora: "8:00 — 20:00 (COT)" },
  { dia: "Sábado", hora: "10:00 — 16:00 (COT)" },
  { dia: "Domingo", hora: "Después de servicio" },
];

const canales = [
  { label: "WhatsApp directo", value: "+57 300 000 0000", href: "https://wa.me/573000000000" },
  { label: "Correo", value: "hola@elegi2.co", href: "mailto:hola@elegi2.co" },
  { label: "Instagram", value: "@elegi2", href: "https://instagram.com" },
];
---

<section
  id="contacto"
  class="relative bg-ink-soft border-t border-ink-line py-28 md:py-44 overflow-hidden"
>
  <!-- bg type -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-32 -right-20 select-none"
  >
    <span
      class="font-display text-cream/[0.05] leading-none block"
      style="font-size: clamp(20rem, 45vw, 50rem); letter-spacing: -0.06em;"
    >
      ORA
    </span>
  </div>

  <div class="relative max-w-[1600px] mx-auto px-6 md:px-10">
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-9 reveal">
        <p class="eyebrow mb-8">Capítulo 08 — Contáctanos para orar</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(3rem, 9vw, 8.5rem); letter-spacing: -0.05em;"
        >
          ¿Quieres que
          <br />
          <span class="text-cream">oremos juntos?</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-6 md:gap-16">
      <!-- Form -->
      <div class="col-span-12 lg:col-span-7 reveal">
        <p class="font-serif italic text-bone text-xl md:text-2xl leading-relaxed mb-12 max-w-2xl">
          Agenda una llamada con uno de nosotros. 20 minutos. Sin agenda escondida —
          solo dos personas, una conversación, y un Dios que escucha.
        </p>

        <form
          class="space-y-7 bg-ink-soft border border-ink-line p-8 md:p-12"
          onsubmit="event.preventDefault(); this.querySelector('button[type=submit]').textContent = '✓ Te contactaremos pronto'; this.reset();"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <label class="block">
              <span class="field-label">Nombre completo</span>
              <input type="text" required placeholder="Cómo te llamas" class="field" />
            </label>
            <label class="block">
              <span class="field-label">Correo</span>
              <input type="email" required placeholder="tu@correo.com" class="field" />
            </label>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <label class="block">
              <span class="field-label">WhatsApp</span>
              <input type="tel" placeholder="+57 ..." class="field" />
            </label>
            <label class="block">
              <span class="field-label">¿Con quién prefieres hablar?</span>
              <select class="field">
                <option class="bg-ink" value="any">Cualquiera de los 3</option>
                <option class="bg-ink">Juan</option>
                <option class="bg-ink">María</option>
                <option class="bg-ink">Camilo</option>
              </select>
            </label>
          </div>

          <label class="block">
            <span class="field-label">Cuéntanos brevemente</span>
            <textarea
              rows="4"
              class="field font-serif italic text-lg resize-none"
              placeholder="Lo que necesites compartir."
            ></textarea>
          </label>

          <button type="submit" class="btn-elegi w-full justify-center mt-2">
            Programar oración
            <span aria-hidden="true">→</span>
          </button>
        </form>
      </div>

      <!-- Sidebar -->
      <aside class="col-span-12 lg:col-span-4 lg:col-start-9 space-y-12 reveal delay-2">
        <div>
          <p class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-6">
            Horarios
          </p>
          <ul class="space-y-3">
            {
              horarios.map((h) => (
                <li class="flex items-baseline justify-between border-b border-ink-line py-3">
                  <span class="text-sm text-bone">{h.dia}</span>
                  <span class="text-sm text-bone-muted">{h.hora}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <p class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-6">
            O escríbenos directo
          </p>
          <ul class="space-y-4">
            {
              canales.map((c) => (
                <li>
                  <a
                    href={c.href}
                    class="flex items-baseline justify-between border-b border-ink-line py-3 group hover:border-cream transition-colors"
                  >
                    <span class="text-sm text-bone-muted group-hover:text-cream transition-colors">
                      {c.label}
                    </span>
                    <span class="font-serif italic text-cream text-lg">{c.value}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="border border-ink-line p-6 bg-ink/40">
          <p class="font-serif italic text-bone text-base leading-relaxed">
            “Pedid, y se os dará; buscad, y hallaréis; llamad, y se os abrirá.”
          </p>
          <p class="mt-3 text-[12px] tracking-[0.32em] uppercase text-cream-deep">
            Mateo 7:7
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>
