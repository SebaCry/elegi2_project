---
const endpoint = import.meta.env.PUBLIC_FORM_ENDPOINT ?? "";

const canales = [
  { label: "WhatsApp directo", value: "+1 (657) 235-0368", href: "https://wa.me/16572350368" },
  { label: "Correo", value: "hola@elegi2.co", href: "mailto:hola@elegi2.co" },
  { label: "Instagram", value: "@elegi2.0", href: "https://www.instagram.com/elegi2.0/" },
];
---

<section
  id="contacto"
  class="relative bg-ink-soft border-t border-ink-line py-16 md:py-20 overflow-hidden"
>
  <!-- bg type -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-32 -right-20 select-none"
  >
    <span
      class="font-display text-cream/[0.05] leading-none block"
      style="font-size: clamp(20rem, 45vw, 50rem); letter-spacing: -0.06em;"
    >
      ORA
    </span>
  </div>

  <div class="relative max-w-[1600px] mx-auto px-6 md:px-10">
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-9 reveal">
        <p class="eyebrow mb-8">Contáctanos para orar</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(3rem, 9vw, 8.5rem); letter-spacing: -0.05em;"
        >
          ¿Quieres que
          <br />
          <span class="text-cream">oremos juntos?</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-6 md:gap-16">
      <!-- Form -->
      <div class="col-span-12 lg:col-span-7 reveal">
        <p class="font-serif italic text-bone text-2xl md:text-3xl leading-relaxed mb-12 max-w-2xl">
          Agenda una llamada con uno de nosotros. 20 minutos. Sin agenda escondida —
          solo dos personas, una conversación, y un Dios que escucha.
        </p>

        <form
          data-contact-form
          data-endpoint={endpoint}
          class="space-y-7 bg-ink-soft border border-ink-line p-8 md:p-12"
          novalidate
        >
          <input type="hidden" name="type" value="contacto" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <label class="block">
              <span class="field-label">Nombre completo</span>
              <input
                type="text"
                name="name"
                required
                placeholder="Cómo te llamas"
                class="field"
                autocomplete="name"
              />
            </label>
            <label class="block">
              <span class="field-label">Correo</span>
              <input
                type="email"
                name="email"
                required
                placeholder="tu@correo.com"
                class="field"
                autocomplete="email"
              />
            </label>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <label class="block">
              <span class="field-label">WhatsApp</span>
              <input
                type="tel"
                name="phone"
                placeholder="+57 ..."
                class="field"
                autocomplete="tel"
              />
            </label>
            <label class="block">
              <span class="field-label">¿Con quién prefieres hablar?</span>
              <select name="pastor" class="field">
                <option class="bg-ink" value="Cualquiera">Cualquiera de los 3</option>
                <option class="bg-ink" value="Juan">Juan</option>
                <option class="bg-ink" value="María">María</option>
                <option class="bg-ink" value="Camilo">Camilo</option>
              </select>
            </label>
          </div>

          <label class="block">
            <span class="field-label">Cuéntanos brevemente</span>
            <textarea
              name="message"
              rows="4"
              class="field font-serif italic text-lg resize-none"
              placeholder="Lo que necesites compartir."
            ></textarea>
          </label>

          <button type="submit" data-submit class="btn-elegi w-full justify-center mt-2">
            <span data-label>Programar oración</span>
            <span data-arrow aria-hidden="true">→</span>
          </button>

          <p
            data-status
            role="status"
            aria-live="polite"
            class="text-sm font-serif italic text-bone-muted min-h-[1.5rem]"
          ></p>
        </form>
      </div>

      <!-- Sidebar -->
      <aside class="col-span-12 lg:col-span-4 lg:col-start-9 space-y-12 reveal delay-2">
        <div>
          <p class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-6">
            O escríbenos directo
          </p>
          <ul class="space-y-4">
            {
              canales.map((c) => (
                <li>
                  <a
                    href={c.href}
                    class="flex items-baseline justify-between border-b border-ink-line py-3 group hover:border-cream transition-colors"
                  >
                    <span class="text-sm text-bone-muted group-hover:text-cream transition-colors">
                      {c.label}
                    </span>
                    <span class="font-serif italic text-cream text-xl">{c.value}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="border border-ink-line p-6 bg-ink/40">
          <p class="font-serif italic text-bone text-lg leading-relaxed">
            “Pedid, y se os dará; buscad, y hallaréis; llamad, y se os abrirá.”
          </p>
          <p class="mt-3 text-[12px] tracking-[0.32em] uppercase text-cream-deep">
            Mateo 7:7
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  type FormState = "idle" | "loading" | "ok" | "error";

  const forms = document.querySelectorAll<HTMLFormElement>("[data-contact-form]");

  forms.forEach((form) => {
    const button = form.querySelector<HTMLButtonElement>("[data-submit]")!;
    const labelEl = form.querySelector<HTMLSpanElement>("[data-label]")!;
    const arrowEl = form.querySelector<HTMLSpanElement>("[data-arrow]")!;
    const statusEl = form.querySelector<HTMLParagraphElement>("[data-status]")!;
    const endpoint = form.dataset.endpoint || "";
    const originalLabel = labelEl.textContent || "Programar oración";

    const setState = (state: FormState, message = "") => {
      statusEl.textContent = message;
      statusEl.classList.remove("text-cream", "text-blood", "text-bone-muted");
      if (state === "ok") {
        statusEl.classList.add("text-cream");
        labelEl.textContent = "✓ Te contactaremos pronto";
        arrowEl.style.display = "none";
        button.disabled = true;
      } else if (state === "error") {
        statusEl.classList.add("text-blood");
        labelEl.textContent = originalLabel;
        arrowEl.style.display = "";
        button.disabled = false;
      } else if (state === "loading") {
        statusEl.classList.add("text-bone-muted");
        labelEl.textContent = "Enviando…";
        arrowEl.style.display = "none";
        button.disabled = true;
      } else {
        statusEl.classList.add("text-bone-muted");
        labelEl.textContent = originalLabel;
        arrowEl.style.display = "";
        button.disabled = false;
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const name = (form.elements.namedItem("name") as HTMLInputElement)?.value?.trim();
      const email = (form.elements.namedItem("email") as HTMLInputElement)?.value?.trim();
      if (!name || !email) {
        setState("error", "Faltan tu nombre y correo para responderte.");
        return;
      }

      if (!endpoint) {
        setState(
          "error",
          "Aún no hay endpoint configurado. Avisa al admin (falta PUBLIC_FORM_ENDPOINT)."
        );
        return;
      }

      setState("loading");

      try {
        const data = new FormData(form);
        const body = new URLSearchParams();
        data.forEach((value, key) => body.append(key, value.toString()));
        body.append("_ua", navigator.userAgent);

        const res = await fetch(endpoint, {
          method: "POST",
          body,
        });

        if (!res.ok) throw new Error("HTTP " + res.status);

        let payload: { ok?: boolean; error?: string } = {};
        try {
          payload = await res.json();
        } catch {
          // tolerar respuesta no-JSON
        }
        if (payload && payload.ok === false) throw new Error(payload.error || "Error");

        form.reset();
        setState("ok", "Recibido. Uno de los influencers te escribirá pronto.");
      } catch (err) {
        console.error(err);
        setState(
          "error",
          "No pudimos enviar tu mensaje. Inténtalo de nuevo o escríbenos por WhatsApp."
        );
      }
    });
  });
</script>
