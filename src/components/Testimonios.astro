---
const testimonios = [
  {
    name: "Valentina, 24",
    place: "Bogotá",
    text: "Llegué a Elegi2 buscando una respuesta y encontré una conversación. Hace 6 meses no oraba. Hoy lo hago todos los días.",
  },
  {
    name: "Esteban, 31",
    place: "Cali",
    text: "Pensé que la fe era para otra gente. Que ya era tarde para mí. Resulta que Él me estaba esperando.",
  },
  {
    name: "Laura, 40",
    place: "Pereira",
    text: "Mi mamá me compartió un video. Ese mismo día decidí volver. No sabía cuánto necesitaba ese mensaje hasta que lo escuché.",
  },
];
---

<section class="relative bg-ink py-28 md:py-40 border-t border-ink-line overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 md:px-10">
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-7 reveal">
        <p class="eyebrow mb-8">Capítulo 07 — Testimonios</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          Lo que pasa cuando
          <br />
          <span class="text-cream">Él entra.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink-line border border-ink-line">
      {
        testimonios.map((t, i) => (
          <article
            class:list={[
              "bg-ink-soft p-8 md:p-12 group hover:bg-ink transition-colors duration-700 reveal",
              `delay-${i + 1}`,
            ]}
          >
            <span class="font-display text-cream text-7xl leading-none block mb-8">
              “
            </span>
            <p class="font-serif italic text-bone text-xl md:text-2xl leading-snug mb-10 min-h-[10rem]">
              {t.text}
            </p>
            <div class="border-t border-ink-line pt-5 flex items-center justify-between">
              <span class="text-sm text-bone">{t.name}</span>
              <span class="text-[12px] tracking-[0.32em] uppercase text-cream-deep">
                {t.place}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
