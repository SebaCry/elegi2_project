---
const voces = [
  {
    name: "Juan Pérez",
    role: "Comunicador · Bogotá",
    image: "/img/juan.png",
    quote: "Cuando necesito un milagro, vuelvo a la Palabra. Ahí siempre encuentro respuesta.",
    handle: "@juan.elegido",
  },
  {
    name: "María González",
    role: "Influencer · Medellín",
    image: "/img/maria.png",
    quote: "Momentico — yo también llegué con preguntas, y Él respondió todas.",
    handle: "@maria.elegida",
  },
  {
    name: "Camilo Ríos",
    role: "Líder de comunidad · Cali",
    image: "/img/juan.png",
    quote: "Compartir el evangelio no es un trabajo, es un privilegio que se nos regaló.",
    handle: "@camilo.elegido",
  },
];
---

<section
  id="nosotros"
  class="relative bg-ink-soft border-t border-ink-line py-28 md:py-40 overflow-hidden"
>
  <div class="max-w-[1600px] mx-auto px-6 md:px-10">
    <!-- Header editorial -->
    <div class="grid grid-cols-12 gap-6 items-end mb-20">
      <div class="col-span-12 md:col-span-7 reveal">
        <p class="eyebrow mb-8">Capítulo 01 — Quiénes somos</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          Tres caminos
          <br />
          <span class="text-outline">que se cruzaron</span>
          <br />
          en una sola Voz.
        </h2>
      </div>
      <div class="col-span-12 md:col-span-4 md:col-start-9 reveal delay-2">
        <p class="font-serif italic text-bone text-lg leading-relaxed">
          Somos tres voces de Colombia con historias distintas, ciudades distintas y
          edades distintas — unidos por una sola convicción: que el evangelio es la
          mejor noticia que jamás escucharemos.
        </p>
      </div>
    </div>

    <!-- 3 vocesos — layout asimétrico magazine -->
    <div class="grid grid-cols-12 gap-6 md:gap-10">
      {
        voces.map((v, i) => (
          <article
            class:list={[
              "col-span-12 md:col-span-6 lg:col-span-4 reveal group",
              i === 1 && "lg:translate-y-16",
              i === 2 && "lg:translate-y-8",
              `delay-${i + 1}`,
            ]}
          >
            <figure class="relative overflow-hidden bg-ink">
              <img
                src={v.image}
                alt={v.name}
                class="w-full h-[440px] md:h-[520px] object-cover grayscale-[40%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000 ease-out"
                loading="lazy"
              />
              <span
                class="absolute top-4 left-4 text-[12px] tracking-[0.32em] uppercase text-cream bg-ink/80 backdrop-blur-sm px-3 py-1.5"
              >
                0{i + 1}
              </span>
              <div
                class="absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-ink via-ink/80 to-transparent"
              >
                <p class="font-display text-bone text-3xl uppercase tracking-tight leading-none">
                  {v.name}
                </p>
                <p class="mt-2 text-[13px] tracking-[0.28em] uppercase text-cream-deep">
                  {v.role}
                </p>
              </div>
            </figure>

            <blockquote class="mt-6 font-serif italic text-bone text-xl leading-snug">
              <span class="text-cream text-3xl mr-1">“</span>
              {v.quote}
            </blockquote>

            <a
              href="#"
              class="mt-5 inline-flex items-center gap-3 text-[13px] tracking-[0.28em] uppercase text-cream border-b border-cream/30 pb-1 hover:border-cream"
            >
              {v.handle}
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))
      }
    </div>

    <!-- Stat band -->
    <div class="mt-32 grid grid-cols-2 md:grid-cols-4 gap-px bg-ink-line border border-ink-line reveal">
      {
        [
          { n: "+2.5M", l: "Personas alcanzadas" },
          { n: "+30", l: "Iglesias aliadas" },
          { n: "365", l: "Días orando juntos" },
          { n: "1", l: "Solo propósito" },
        ].map((s) => (
          <div class="bg-ink-soft p-8 md:p-10 group hover:bg-ink transition-colors duration-700">
            <span
              class="block font-display text-cream uppercase leading-none"
              style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em;"
            >
              {s.n}
            </span>
            <span class="mt-3 block text-[12px] tracking-[0.32em] uppercase text-bone-muted">
              {s.l}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
