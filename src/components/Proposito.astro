---
const pilares = [
  {
    n: "01",
    title: "Fe",
    text: "Una fe que no se ve obligada — se ve provocada. Volver a creer como niños, sin reservas.",
    verse: "“La fe es la certeza de lo que se espera.” — Hebreos 11:1",
  },
  {
    n: "02",
    title: "Vida",
    text: "Vivir distinto. Una vida que se note, que tenga sabor — sal de la tierra, luz del mundo.",
    verse: "“Yo he venido para que tengan vida en abundancia.” — Juan 10:10",
  },
  {
    n: "03",
    title: "Esperanza",
    text: "No el optimismo barato — la esperanza ancla, la que sostiene aun cuando todo parece perdido.",
    verse: "“La esperanza no avergüenza.” — Romanos 5:5",
  },
];
---

<section
  id="proposito"
  class="relative bg-ink py-16 md:py-22 overflow-hidden"
>
  <!-- texto outline gigante de fondo -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 flex items-center justify-center select-none"
  >
    <span
      class="font-display text-outline opacity-[0.08] leading-none"
      style="font-size: clamp(20rem, 38vw, 50rem); letter-spacing: -0.06em;"
    >
      ELEGI2
    </span>
  </div>

  <div class="relative max-w-[1600px] mx-auto px-6 md:px-10">
    <!-- Encabezado -->
    <div class="grid grid-cols-12 gap-6 mb-24">
      <div class="col-span-12 md:col-span-8 reveal">
        <p class="eyebrow mb-8">Propósito</p>
        <h2
          class="font-display uppercase text-bone leading-[0.88]"
          style="font-size: clamp(2.5rem, 7vw, 6.5rem); letter-spacing: -0.04em;"
        >
          No vinimos a hablar
          <br />
          de nosotros.
          <br />
          <span class="text-cream">Vinimos a hablar de Él.</span>
        </h2>
      </div>
    </div>

    <!-- Manifiesto central -->
    <div class="reveal mb-24 max-w-3xl mx-auto text-center">
      <p class="font-serif text-2xl md:text-3xl text-bone italic leading-snug">
        Si hoy estás aquí —{" "}
        <span class="text-cream">no es coincidencia.</span>{" "}
        Alguien oró por ti antes de que aprendieras a hablar. Alguien creyó por ti
        cuando dejaste de creer. Y Él —{" "}
        <span class="text-cream">te eligió primero.</span>
      </p>
    </div>

    <!-- 3 pilares -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink-line border border-ink-line">
      {
        pilares.map((p, i) => (
          <article
            class:list={[
              "bg-ink-soft p-10 md:p-12 group relative overflow-hidden reveal",
              `delay-${i + 1}`,
            ]}
          >
            <span
              class="absolute -top-2 -right-2 font-display text-cream/[0.07] leading-none select-none"
              style="font-size: 14rem; letter-spacing: -0.06em;"
            >
              {p.n}
            </span>

            <p class="text-[13px] tracking-[0.32em] uppercase text-cream-deep mb-6">
              Pilar {p.n}
            </p>
            <h3
              class="font-display uppercase text-bone leading-none mb-8"
              style="font-size: clamp(4rem, 8vw, 7rem); letter-spacing: -0.05em;"
            >
              {p.title}
            </h3>
            <p class="text-bone text-lg leading-relaxed mb-8 max-w-sm">{p.text}</p>
            <p class="font-serif italic text-cream text-lg border-t border-ink-line pt-6 max-w-sm">
              {p.verse}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
